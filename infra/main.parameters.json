{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "environmentName": {
            "value": "${AZURE_ENV_NAME}"
        },
        "location": {
            "value": "${AZURE_LOCATION}"
        },
        "backendContainerImage": {
            "value": "${SERVICE_API_IMAGE_NAME}"
        },
        "frontendContainerImage": {
            "value": "${SERVICE_WEB_IMAGE_NAME}"
        },
        "projectName": {
            "value": "shadcn-fastapi"
        },
        "azureOpenAIDeploymentName": {
            "value": "${AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.3-chat}"
        },
        "azureOpenAIApiVersion": {
            "value": "${AZURE_OPENAI_API_VERSION=preview}"
        },
        "azureOpenAIDeploymentsApiVersion": {
            "value": "${AZURE_OPENAI_DEPLOYMENTS_API_VERSION=2024-10-21}"
        },
        "azureOpenAIEmbeddingModel": {
            "value": "${AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large}"
        },
        "postgresAdminLogin": {
            "value": "${POSTGRES_ADMIN_LOGIN=claimsadmin}"
        },
        "postgresAdminPassword": {
            "value": "${POSTGRES_ADMIN_PASSWORD}"
        },
        "postgresDbName": {
            "value": "${POSTGRES_DB_NAME=claims_app}"
        },
        "frontendCustomDomain": {
            "value": "${FRONTEND_CUSTOM_DOMAIN=}"
        }
    }
}
